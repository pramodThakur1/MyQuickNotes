<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.MyApplication" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Custom attributes for Night mode -->
        <item name="appBackgroundColor">#121212</item>
        <item name="appPrimaryTextColor">#E1E1E1</item>
        <item name="appSecondaryTextColor">#AAAAAA</item>
        <item name="appSearchBackgroundColor">#1E1E1E</item>
        <item name="appDrawerBackgroundColor">#121212</item>
        <item name="appBottomBarColor">#1A1A1A</item>
    </style>
</resources>